# =============================================================================
# Wago API — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values marked REQUIRED.

# ─── Database (Turso / libSQL) ─────────────────────────────────
# Turso dashboard → your DB → Connect → libsql URL
TURSO_DATABASE_URL=libsql://your-db-name.turso.io     # REQUIRED
# Turso dashboard → your DB → Connect → Auth Token
TURSO_AUTH_TOKEN=your-turso-auth-token
# For local dev with SQLite (no Turso):
# TURSO_DATABASE_URL=file:local.db
# TURSO_AUTH_TOKEN=

# ─── Authentication ────────────────────────────────────────────
# Supabase project URL (Settings → API)
SUPABASE_URL=https://xxx.supabase.co                    # REQUIRED

# ─── Orchestration ──────────────────────────────────────────────
# Which orchestrator: local (docker), k8s (prod), mock (dev no WAHA)
ORCHESTRATOR=local
NODE_ENV=development

# ─── Local orchestrator (ORCHESTRATOR=local) ────────────────────
WAHA_HOST=localhost       # or 'waha' if using docker compose
WAHA_API_KEY=devkey       # shared secret with WAHA container
WAHA_PORT=3000            # WAHA default port (not 3002)
WAHA_MAX_SESSIONS=1       # 1 for Core, ~50 for Plus

# ─── Kubernetes (ORCHESTRATOR=k8s) ──────────────────────────────
# K8S_NAMESPACE=default
# WAHA_STATEFULSET_NAME=waha
# WAHA_HEADLESS_SERVICE=waha
# WAHA_API_KEY=<openssl rand -hex 32>
# KUBECONFIG=~/.kube/wago.yaml

# ─── Hetzner Cloud (ORCHESTRATOR=hetzner, legacy) ───────────────
# HETZNER_API_TOKEN=your-hetzner-api-token
# HETZNER_NETWORK_ID=your-network-id
# HETZNER_SERVER_TYPE=cx23
# HETZNER_LOCATION=nbg1
# DATABASE_URL=postgresql://postgres:PASSWORD@db.xxx.supabase.co:5432/postgres

# ─── Stripe Billing (optional, not yet configured) ─────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PRICE_ID=price_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── URLs ──────────────────────────────────────────────────────
PORT=3001
API_URL=http://localhost:3001
FRONTEND_URL=http://localhost:3000

# ─── Redis (BullMQ) ────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
# Docker Compose: redis://redis:6379
