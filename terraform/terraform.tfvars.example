# Copy to terraform.tfvars and fill in real values.
# NEVER commit terraform.tfvars — it contains secrets.

hcloud_token         = "hcloud_..."
ssh_public_key_path  = "~/.ssh/wago_k8s.pub"
ssh_private_key_path = "~/.ssh/wago_k8s"

# Restrict to your IP in production
firewall_ssh_source      = ["YOUR_IP/32"]
firewall_kube_api_source = ["YOUR_IP/32"]

# Application secrets
waha_api_key          = "your-waha-api-key"
database_url          = "postgresql://postgres:PASSWORD@db.xxx.supabase.co:5432/postgres"
supabase_url          = "https://xxx.supabase.co"
stripe_secret_key     = "sk_live_..."
stripe_price_id       = "price_..."
stripe_webhook_secret = "whsec_..."

# URLs
api_url      = "https://api.wago.com"
frontend_url = "https://wago.com"
api_image    = "ghcr.io/noclick/wago-api:latest"
